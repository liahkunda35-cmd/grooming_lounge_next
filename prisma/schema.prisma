generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model GalleryCategory {
  id        String        @id @default(cuid())
  slug      String        @unique
  name      String
  section   String
  sortOrder Int           @default(0)
  layout    String        @default("grid")
  isActive  Boolean       @default(true)
  items     GalleryItem[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model GalleryItem {
  id          String          @id @default(cuid())
  categoryId  String
  category    GalleryCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  mediaUrl    String
  caption     String?
  altText     String?
  overlayText String?
  badgeType   String?
  mediaType   String          @default("image")
  sortOrder   Int             @default(0)
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model SeasonalTheme {
  id        String    @id @default(cuid())
  key       String    @unique
  name      String
  isActive  Boolean   @default(false)
  startsAt  DateTime?
  endsAt    DateTime?
  config    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model StaffMember {
  id          String   @id @default(cuid())
  slug        String   @unique
  category    String
  name        String
  title       String
  rating      Float    @default(5)
  photoUrl    String?
  specialties String
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BookableService {
  id          String   @id @default(cuid())
  category    String
  label       String
  price       Int?
  group       String   @default("Services")
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Announcement {
  id        String    @id @default(cuid())
  title     String
  message   String
  isEnabled Boolean   @default(true)
  isPinned  Boolean   @default(false)
  placement String    @default("all")
  startsAt  DateTime?
  endsAt    DateTime?
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}
